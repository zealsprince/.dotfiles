// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // Two Claude accounts as separate ACP agents, each pinned to its own
  // CLAUDE_CONFIG_DIR so logins/sessions don't collide. Run `/login` in each
  // thread once to authenticate the matching account. Dirs are created by the
  // Nix home activation (see .nixos/home.nix installZedConfig).
  "agent_servers": {
    "Claude (Personal)": {
      "type": "custom",
      "command": "npx",
      "args": ["-y", "@agentclientprotocol/claude-agent-acp@0.45.0"],
      "env": {
        "CLAUDE_CONFIG_DIR": "/home/zealsprince/.claude-personal",
        "SSH_AUTH_SOCK": "/home/zealsprince/.1password/agent.sock",
      },
      "default_config_options": {
        "mode": "dontAsk",
      },
    },
    "Claude (Work)": {
      // No CLAUDE_CONFIG_DIR: work uses the DEFAULT Claude config (~/.claude),
      // the same one bare `claude` and VSCode use, so they never drift apart.
      "type": "custom",
      "command": "npx",
      "args": ["-y", "@agentclientprotocol/claude-agent-acp@0.45.0"],
      "env": {
        "SSH_AUTH_SOCK": "/home/zealsprince/.1password/agent.sock",
      },
      "default_config_options": {
        "mode": "dontAsk",
      },
    },
    "Claude (Vera)": {
      "type": "custom",
      "command": "npx",
      "args": ["-y", "@agentclientprotocol/claude-agent-acp@0.45.0"],
      "env": {
        "CLAUDE_CONFIG_DIR": "/home/zealsprince/.claude-vera",
        "SSH_AUTH_SOCK": "/home/zealsprince/.1password/agent.sock",
      },
      "default_config_options": {
        "mode": "dontAsk",
      },
    },
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "outline_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
    "hide_hidden": false,
    "hide_root": true,
    "entry_spacing": "standard",
  },
  "terminal": {
    "dock": "bottom",
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "redact_private_values": true,
  "tabs": {
    "file_icons": true,
    "git_status": false,
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_menus": false,
  },
  "debugger": {
    "dock": "right",
  },
  "colorize_brackets": true,
  "indent_guides": {
    "coloring": "fixed",
  },
  "minimap": {
    "max_width_columns": 80,
    "thumb_border": "full",
    "thumb": "always",
    "show": "always",
  },
  "agent_buffer_font_size": 11.0,
  "agent_ui_font_size": 13.0,
  "buffer_font_weight": 400.0,
  "git_panel": {
    "dock": "right",
  },
  "icon_theme": "Material Icon Theme",
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
    "tool_permissions": {
      "default": "allow",
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.6",
        "enable_thinking": false,
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.2-codex",
        "enable_thinking": false,
      },
      {
        "provider": "copilot_chat",
        "model": "gemini-3.1-pro-preview",
        "enable_thinking": true,
        "effort": "high",
      },
    ],
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
    },
    "model_parameters": [],
  },
  "ui_font_size": 15.0,
  "buffer_font_size": 11.0,
  "theme": {
    "dark": "Neko (Dark)",
    "light": "Ayu Light",
  },
}
