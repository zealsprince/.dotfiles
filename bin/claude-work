#!/usr/bin/env bash
# Run the Claude Code CLI against the work account.
#
# Work now lives in the DEFAULT config dir (~/.claude), the same one the bare
# `claude` command and the VSCode extension use. So terminal, VSCode, and this
# launcher all share one work login, trust, and skills state - no more drift
# between them. This wrapper stays for muscle memory (and the Zed "Claude
# (Work)" agent); it is just `claude` with no CLAUDE_CONFIG_DIR override.
#
# Personal and Vera keep their own dirs via claude-personal / claude-vera.
exec claude "$@"
