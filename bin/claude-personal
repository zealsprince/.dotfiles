#!/usr/bin/env bash
# Run the Claude Code CLI against the personal account.
# Login/session live in a dedicated CLAUDE_CONFIG_DIR so this never collides
# with the work account (see also: Zed agent "Claude (Personal)").
#
# First run: `claude-personal` then `/login` to authenticate.
# Piping works as usual, e.g.:
#   echo "summarize this" | claude-personal -p
#   git diff | claude-personal -p "review these changes"
export CLAUDE_CONFIG_DIR="$HOME/.claude-personal"
exec claude "$@"
